# LLM Providers (at least one recommended)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
AEGIS_LLM_PROVIDER=openai
AEGIS_LLM_MODEL=gpt-4o-mini

# Threat Intelligence (optional — works offline without keys)
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=

# Skills catalog path (Anthropic Cybersecurity Skills repo)
AEGIS_SKILLS_PATH=/path/to/Anthropic-Cybersecurity-Skills-main

# Database
AEGIS_DATABASE_URL=sqlite:///./data/aegis.db

# API
AEGIS_API_HOST=0.0.0.0
AEGIS_API_PORT=8000
AEGIS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Detection thresholds
AEGIS_ML_CONFIDENCE_THRESHOLD=55
AEGIS_AI_CONFIDENCE_THRESHOLD=60